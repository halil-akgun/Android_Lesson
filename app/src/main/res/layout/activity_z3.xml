<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
                name="z3Activity"
                type="com.android_lesson.Z3Activity" />

        <variable
                name="result"
                type="String" />

        <import type="android.view.View" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:context=".Z3Activity">

        <TextView
                android:text="@{result}"
                android:textColor="@{Integer.parseInt(result) > 30 ? @color/black : @color/colorAccent}"
                android:visibility="@{Integer.parseInt(result) > 60 ? View.INVISIBLE : View.VISIBLE}"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/textViewMVVM_Result"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="133dp"
                android:textSize="34sp" />

        <EditText
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:autofillHints="number"
                android:ems="10"
                android:id="@+id/editTextMVVM_Number1"
                android:hint="Number 1"
                android:inputType="number"
                android:textSize="20sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="77dp"
                app:layout_constraintTop_toBottomOf="@+id/textViewMVVM_Result" />

        <EditText
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:autofillHints="number"
                android:ems="10"
                android:id="@+id/editTextMVVM_Number2"
                android:hint="Number 2"
                android:inputType="number"
                android:textSize="20sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="33dp"
                app:layout_constraintTop_toBottomOf="@+id/editTextMVVM_Number1" />

        <Button
                android:text="➕   Add"
                android:onClick="@{() -> z3Activity.buttonAdd()}"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/buttonMVVM_Add"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="144dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintEnd_toStartOf="@+id/buttonMVVM_Mul" />

        <Button
                android:text="✖️   Mul"
                android:onClick="@{() -> z3Activity.buttonMul()}"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/buttonMVVM_Mul"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="144dp"
                app:layout_constraintStart_toEndOf="@+id/buttonMVVM_Add"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintEnd_toEndOf="parent" />

        <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragment_container"
                android:name="com.android_lesson.Z3Fragment"
                android:layout_width="0dp"
                android:layout_height="33dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
